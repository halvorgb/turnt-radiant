<?xml version="1.0"?>
<!--
build commands
[RadiantPath]: path to Radiant .. C:\Program Files\Gtkradiant
[EnginePath]: path to the engine .. C:\TURNT\ C:\Program Files\TURNT\ /usr/local/games/TURNT/
-->
<project version="2.0">
  <var name="turnt">"[EnginePath]turnt"</var>
  <build name="Launch turnt in import mode">
    <command>[turnt] --import="[MapFile]"</command>
  </build>
  <!-- windows only... do cp instead of copy on real OSes -->
  <build name="[Powershell]: Copy default mapping to mapname.json">
    <command>powershell -Command "Copy-Item '[EnginePath]map_wip/default_mapping.json' '[EnginePath]map_wip/[MapName].json'"</command>
  </build>  
  <build name="">
  </build>
  <build name="----">
  </build>
  <build name="">
  </build>
  <build name="---- Keep the game running, use 'Reimport Map' to refresh ----">
  </build>
</project>


